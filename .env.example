# ═══════════════════════════════════════════════════════════════
# OpenGravity — Variables de entorno (TEMPLATE)
# ═══════════════════════════════════════════════════════════════
# Copia este archivo a .env y completa los valores.
# Las marcadas [REQUERIDO] deben estar presentes o el server no arranca.

# ── Auth (NextAuth.js) [REQUERIDO en prod] ──────────────────────
# Generar con: openssl rand -hex 32
NEXTAUTH_SECRET=your-nextauth-secret-hex
# En Vercel esto es auto: https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000
# OAuth providers (al menos uno)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Stripe (cobros) [REQUERIDO para vender] ────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Storage (Upstash Redis) [REQUERIDO] ─────────────────────────
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── LLM (DeepSeek) [REQUERIDO] ──────────────────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-key

# ── Research (Tavily) [REQUERIDO] ───────────────────────────────
TAVILY_API_KEY=tvly-your-tavily-key

# ── Auth [REQUERIDO] ────────────────────────────────────────────
# Secret compartido entre Vercel Cron y tus rutas /api/cron/*
# Genéralo con: openssl rand -hex 32
CRON_SECRET=your-cron-secret-hex
# API key para ingesta externa (POST /api/ingest, worker Lead Sniper)
OG_API_KEY=your-api-key-hex

# ── Búsqueda web (opcional, hay fallback) ───────────────────────
BRAVE_API_KEY=
JINA_API_KEY=

# ── TTS (opcional, hay fallback) ────────────────────────────────
OPENAI_API_KEY=

# ── Telegram (opcional) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ── Facebook Poster (opcional) ──────────────────────────────────
FB_PAGE_ID=
FB_PAGE_TOKEN=

# ── Cloudflare Workers AI (opcional, para memoria) ──────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_EMAIL=
CLOUDFLARE_GLOBAL_KEY=

# ── Gemini (opcional, fallback summarizer) ──────────────────────
GEMINI_KEY_1=

# ── Lead Sniper worker (opcional) ───────────────────────────────
# URL del worker externo que ejecuta el scraping real (Railway/Render)
LEAD_SNIPER_WEBHOOK_URL=
LEAD_SNIPER_WEBHOOK_TOKEN=

# ── Firebase (cambio desde hardcoded C1) ────────────────────────
# Config del proyecto Firebase de la shop (cron facebook-poster)
NEXT_PUBLIC_FB_SHOP_API_KEY=
NEXT_PUBLIC_FB_SHOP_AUTH_DOMAIN=
NEXT_PUBLIC_FB_SHOP_PROJECT_ID=
NEXT_PUBLIC_FB_SHOP_STORAGE_BUCKET=
NEXT_PUBLIC_FB_SHOP_SENDER_ID=
NEXT_PUBLIC_FB_SHOP_APP_ID=
